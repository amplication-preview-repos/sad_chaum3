datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  chats       Chat[]
  companySize String?
  createdAt   DateTime    @default(now())
  id          String      @id @default(cuid())
  interviews  Interview[]
  jobs        Job[]
  logo        Json?
  name        String?
  recruiter   String?
  sector      String?
  updatedAt   DateTime    @updatedAt
}

model Job {
  company      Company?    @relation(fields: [companyId], references: [id])
  companyId    String?
  createdAt    DateTime    @default(now())
  description  String?
  id           String      @id @default(cuid())
  interviews   Interview[]
  requirements String?
  salary       Int?
  title        String?
  updatedAt    DateTime    @updatedAt
}

model Notification {
  createdAt DateTime                   @default(now())
  id        String                     @id @default(cuid())
  message   String?
  status    EnumNotificationStatus?
  typeField EnumNotificationTypeField?
  updatedAt DateTime                   @updatedAt
  user      User?                      @relation(fields: [userId], references: [id])
  userId    String?
}

model Chat {
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  messages  Json?
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Interview {
  answers   Json?
  company   Company?             @relation(fields: [companyId], references: [id])
  companyId String?
  createdAt DateTime             @default(now())
  id        String               @id @default(cuid())
  job       Job?                 @relation(fields: [jobId], references: [id])
  jobId     String?
  questions String?
  ranking   Int?
  status    EnumInterviewStatus?
  updatedAt DateTime             @updatedAt
}

model User {
  age               Int?
  chats             Chat[]
  createdAt         DateTime       @default(now())
  cv                Json?
  education         Json?
  email             String?        @unique
  firstName         String?
  id                String         @id @default(cuid())
  lastName          String?
  notifications     Notification[]
  password          String
  phone             String?
  roles             Json
  skills            String?
  updatedAt         DateTime       @updatedAt
  username          String         @unique
  videoPresentation Json?
  workExperience    Json?
}

enum EnumNotificationStatus {
  Option1
}

enum EnumNotificationTypeField {
  Option1
}

enum EnumInterviewStatus {
  Option1
}
